{
  "dxt_version": "0.1",
  "name": "wateen-open-api-v1.0-mcp",
  "version": "1.0.0",
  "description": "The official MCP Server for the Wateen OpenAPI V1 0 API",
  "author": {
    "name": "Wateen OpenAPI V1 0",
    "email": ""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/M0-AR/wateen-open-api-v1.0.git"
  },
  "homepage": "https://github.com/M0-AR/wateen-open-api-v1.0/tree/main/packages/mcp-server#readme",
  "documentation": "",
  "server": {
    "type": "node",
    "entry_point": "${__dirname}/index.js",
    "mcp_config": {
      "command": "node",
      "args": ["${__dirname}/index.js"],
      "env": {
        "WATEEN_OPENAPI_V1_0_API_KEY": "${user_config.WATEEN_OPENAPI_V1_0_API_KEY}"
      }
    }
  },
  "user_config": {
    "WATEEN_OPENAPI_V1_0_API_KEY": {
      "title": "api_key",
      "description": "",
      "required": false,
      "type": "string"
    }
  },
  "tools_generated": true,
  "compatibility": {
    "runtimes": {
      "node": ">=18.0.0"
    }
  },
  "keywords": ["api"]
}
